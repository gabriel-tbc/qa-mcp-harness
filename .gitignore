# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual env
.venv/
venv/

# Local config (per-machine). Template: .env.example
.env

# Third-party red-team references — cloned locally as a payload/technique
# corpus, never imported as code. See external/README.md.
external/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# pytest
.pytest_cache/

# Eval report artifacts (Layer 3/4). Regenerated by the runner.
reports/

# Local target configs hold per-machine paths (and possibly auth). Track only
# the *.example.toml templates and the example-http.toml reference.
targets/*.toml
!targets/*.example.toml
!targets/example-http.toml
