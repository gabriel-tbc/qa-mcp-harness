# qa-mcp-harness — local config. Copy to .env and edit.

# Which target (file under targets/, without the .toml extension) to test against.
# Default: qa-toolkit-local
HARNESS_TARGET=qa-toolkit-local

# Required ONLY for Layer 3 (tool-calling evals), which drives a real LLM.
# Leave empty for Layer 2 (contract) tests.
ANTHROPIC_API_KEY=

# Model id used by Layer 3. Set to a current model available in your account
# (e.g. a Claude Sonnet id). Required for the real eval run.
HARNESS_MODEL=
